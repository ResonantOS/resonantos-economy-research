{
  "dispatch_id": "fixture-pass-route-menu-overlay",
  "intent": {
    "raw": "refine ambiguous target",
    "objective": "Choose a bounded refinement route before execution."
  },
  "mode": "sequence",
  "route_menu": {
    "context_hint": "Ambiguous route choice.",
    "items": [
      {"id": "baseline", "label": "Baseline", "description": "Use normal sequence.", "pattern": "sequential"},
      {"id": "tension", "label": "Tension", "description": "Use dialectic review.", "pattern": "dialectic"}
    ],
    "selected_item_id": "baseline"
  },
  "techniques": ["route_menu", "one_or_more_option_set", "approval_checkpoint"],
  "steps": [
    {
      "step_id": "s1",
      "name": "Select route",
      "capability_ref": "refine",
      "pattern": "decision",
      "techniques": ["route_menu", "one_or_more_option_set", "approval_checkpoint"],
      "inputs": [{"kind": "intent", "ref": "intent.raw"}],
      "outputs": [{"kind": "decision", "ref": "selected-route"}],
      "stop_conditions": ["block if no route can be selected"]
    }
  ],
  "gates": [
    {"gate_id": "g1", "kind": "decision", "owner": "refine", "condition": "Route menu selection is recorded.", "on_fail": "block"}
  ],
  "observability": {
    "dispatch_id_required": true,
    "trace_events": ["dispatch_validated"],
    "signal_grouping": "dispatch_id"
  }
}
