      "outputs": [{"kind": "handoff", "ref": "handoff.md"}],
      "stop_conditions": ["block if boundary references are invalid"]
    }
  ],
  "gates": [
    {
      "gate_id": "g1",
      "kind": "quality",
      "owner": "dispatch-spec",
      "condition": "Boundary step references must exist.",
