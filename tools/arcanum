- Final synthesis: native Refine requires `jq` to write evidence indexes.
BLOCK
		return 0
	fi
	local target preset research run_dir stage_jsonl status1 status2 status3 status5 status6 status7 status8 status9 status10 final_status dispatch_validation
	target="$(extract_refine_target "$request")"
	preset="$(extract_refine_preset "$request")"
	research="$(extract_refine_research "$request")"
	if [[ -z "$target" ]]; then
		cat > "$output_abs" <<'BLOCK'
## Refine Result

- Target: `unspecified`
- Status: `block`
- Final synthesis: blocked before materializing the refinement run because the command arguments were empty. Refine requires a target folder, artifact, idea, design concern, plan, work-pack, or repository area.
- Recommended next routes: rerun `refine` with a concrete target and optional `--preset` / `--research` flags.
BLOCK
		return 0
	fi
	run_dir="$(resolve_refine_run_dir "$target" "$request" "$run_stamp")"
	mkdir -p "$run_dir/stages"
	stage_jsonl="$run_dir/stages/native-stage-evidence.jsonl"
	: > "$stage_jsonl"
	write_native_refine_seed_if_missing "$run_dir" "$target" "$request" "$preset" "$research"
	dispatch_validation="$(write_native_refine_dispatch "$run_dir" "$target" "$request" "$preset" "$research")"
	write_native_refine_handoffs "$run_dir" "$target" "$request" "$preset" "$research" "$dispatch_validation"
	cat > "$run_dir/stages/00-observer-envelope.md" <<ZERO
# Observer Envelope

## Status

\`pass\`

## Runtime Topology

Native root Refine orchestration.

## Target

\`$target\`
ZERO
	record_refine_stage "$stage_jsonl" "Task Zero Observer Envelope" "refine" "" "$(rel_path "$run_dir/stages/00-observer-envelope.md")" "pass" "observer envelope prepared" ""
	if [[ "$dispatch_validation" != "pass" ]]; then
		write_refine_block_stage "$run_dir/stages/01-context-builder.md" "Context Builder evidence baseline" "context-builder" "$(resolve_command "context-builder" || true)" "standard" "Dispatch validation failed before stage execution: $dispatch_validation"
		record_refine_stage "$stage_jsonl" "Context Builder evidence baseline" "context-builder" "$(resolve_command "context-builder" || true)" "$(rel_path "$run_dir/stages/01-context-builder.md")" "block" "" "Dispatch validation failed before stage execution: $dispatch_validation"
		write_native_refine_outputs "$run_dir" "$output_abs" "$target" "$request" "$preset" "$research" "$stage_jsonl" "block" "$dispatch_validation"
		return 0
	fi
	status1="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "01-context-builder.md" "Context Builder evidence baseline" "context-builder" "standard" "target=$target --strict --emit both --handoff runtime --persist $(rel_path "$run_dir")/context-builder preset=$preset request=$request" "pass" "")"
	status2="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "02-invoke-define.md" "Invoke Define" "invoke" "define" "define refinement target=$target using seed=$(rel_path "$run_dir/REFINE-SEED-PROPOSAL.md") and context=$(rel_path "$run_dir/stages/01-context-builder.md"); preset=$preset; preserve native output contract" "$status1" "Dependency blocked. Context Builder evidence baseline did not produce pass evidence.")"
	status3="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "03-interrogation-refine-review.md" "Interrogation refine-review" "interrogation" "refine-review" "mode=refine-review; review invoke define artifact=$(rel_path "$run_dir/stages/02-invoke-define.md"); target=$target; emit pass flag or block with missing decisions" "$status2" "Dependency blocked. Invoke Define did not produce pass evidence.")"
	write_refine_research_decision "$stage_jsonl" "$run_dir" "$research" "$status3"
	status5="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "05-distill.md" "Distill" "distill" "standard" "distill target=$target using seed=$(rel_path "$run_dir/REFINE-SEED-PROPOSAL.md"), define=$(rel_path "$run_dir/stages/02-invoke-define.md"), review=$(rel_path "$run_dir/stages/03-interrogation-refine-review.md"), research=$(rel_path "$run_dir/stages/04-research-decision.md"); select smallest coherent refinement unit and rejected alternatives" "$status3" "Dependency blocked. Refine review did not produce pass evidence.")"
	status6="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "06-invoke-design.md" "Invoke Redefine / Design" "invoke" "design" "design refinement from distill artifact=$(rel_path "$run_dir/stages/05-distill.md"); target=$target; produce design/redefinition artifact and preserve stage ownership" "$status5" "Dependency blocked. Distill did not produce pass evidence.")"
	status7="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "07-interrogation-refine-design-review.md" "Interrogation refine-design-review" "interrogation" "refine-design-review" "mode=refine-design-review; review design artifact=$(rel_path "$run_dir/stages/06-invoke-design.md"); target=$target; identify repair needs" "$status6" "Dependency blocked. Invoke Design did not produce pass evidence.")"
	status8="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "08-distill-repair.md" "Distill Repair" "distill" "validate" "validate and repair refinement substrate using design=$(rel_path "$run_dir/stages/06-invoke-design.md") and design_review=$(rel_path "$run_dir/stages/07-interrogation-refine-design-review.md"); target=$target" "$status7" "Dependency blocked. Design review did not produce pass evidence.")"
	status9="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "09-invoke-plan.md" "Invoke Plan" "invoke" "plan" "plan non-executed next route from repaired substrate=$(rel_path "$run_dir/stages/08-distill-repair.md"); target=$target; include first SWU or explicit block" "$status8" "Dependency blocked. Distill Repair did not produce pass evidence.")"
	status10="$(run_refine_command_stage "$stage_jsonl" "$run_dir" "10-final-interrogation-and-synthesis.md" "Final Interrogation and Synthesis" "interrogation" "refine-final" "mode=refine-final; review plan=$(rel_path "$run_dir/stages/09-invoke-plan.md"); target=$target; produce final readiness verdict and risks" "$status9" "Dependency blocked. Invoke Plan did not produce pass evidence.")"
	final_status="pass"
	for stage_status in "$status1" "$status2" "$status3" "$status5" "$status6" "$status7" "$status8" "$status9" "$status10"; do
		if [[ "$stage_status" != "pass" ]]; then
			final_status="block"
			break
		fi
	done
	write_native_refine_outputs "$run_dir" "$output_abs" "$target" "$request" "$preset" "$research" "$stage_jsonl" "$final_status" "$dispatch_validation"
}

infer_target_artifact_dir() {
	local request="$1"
	local inferred=""
	if [[ "$request" =~ under[[:space:]]+([^;\ ]+) ]]; then
		inferred="${BASH_REMATCH[1]}"
	elif [[ "$request" =~ in[[:space:]]+([^;\ ]+) ]]; then
		inferred="${BASH_REMATCH[1]}"
	fi
	printf '%s\n' "$inferred"
}

write_expected_command_artifacts() {
	local target_dir="$1"
	local request="$2"
	if [[ -z "$target_dir" ]]; then
		printf -- '- none inferred\n'
		return 0
	fi
	local emitted=0
	local artifact
	for artifact in INVOKE-DEFINE.md INVOKE-DESIGN.md INVOKE-PLAN.md ARCHITECTURE-BUNDLE.md GLOSSARY-CONSISTENCY.md DESIGN-TRANSPORT.md DEFINE-TRANSPORT.md PLAN-TRANSPORT.md IMPLEMENTATION-LAYERING.md WORK-PACK.md EXECUTION-PACK.md REFRESH-REPORT.md REFRESH-PATCH-PROPOSAL.md refresh-report.json; do
		if [[ "$request" == *"$artifact"* ]]; then
			printf -- '- %s/%s\n' "$target_dir" "$artifact"
			emitted=1
		fi
	done
	if [[ "$emitted" -eq 0 ]]; then
		printf -- '- none inferred\n'
	fi
}

write_runtime_handoff() {
	local handoff_file="$1"
	local selected="$2"
	local command_rel="$3"
	local request="$4"
	local requested_output="$5"
	local prompt_text="$6"
	local timeout_seconds="${7:-0}"
	local target_artifact_dir
	target_artifact_dir="$(infer_target_artifact_dir "$request")"
	mkdir -p "$(dirname "$handoff_file")"
	{
	cat <<HANDOFF
# Runtime Handoff

## Objective

Execute Arcanum command "$selected" through the durable runtime runner and preserve the command surface output contract.

## Orchestrator

- orchestrator_id: tools-arcanum
- orchestrator_run_id: $(basename "$(dirname "$handoff_file")")

## Target

- target_kind: command
- target_id: $selected

## Inputs

- command: $selected
- command_file: $command_rel
- request: $request
- requested_output: $requested_output
- target_artifact_dir: ${target_artifact_dir:-none inferred}

## Allowed Write Scope

- $requested_output
- .arcanum/runtime/runs/
- .arcanum/runtime/handoffs/
- .arcanum/observability/runs/arcanum-command/
HANDOFF
	if [[ -n "$target_artifact_dir" ]]; then
		printf -- '- %s\n' "$target_artifact_dir"
	fi
	cat <<HANDOFF

## Expected Outputs

- command output: $requested_output
- runtime RUN.json
- runtime STATUS.json
- runtime events.jsonl

## Expected Command-Owned Artifacts

HANDOFF
	write_expected_command_artifacts "$target_artifact_dir" "$request"
	cat <<HANDOFF

## Validation

- requested output path exists
- runtime RUN.json and STATUS.json are valid JSON
- runtime status is passed, flagged, blocked, or failed
- expected command-owned artifacts exist when listed

## Blocked Conditions

- command cannot be resolved
- runtime runner is unavailable
- adapter is unavailable
- requested output cannot be written
- Codex cannot start safely

## Adapter Preference

- adapter_id: local-skill
- timeout_seconds: $timeout_seconds

## Nesting Policy

- loop_role: root
- loop_id: arcanum-command-$selected
- parent_loop_id: null
- parent_run_id: null

## Command Prompt

BEGIN COMMAND PROMPT
$prompt_text
END COMMAND PROMPT
HANDOFF
	} > "$handoff_file"
}

write_envelope_event() {
	local events_file="$1"
	local run_id="$2"
	local event="$3"
	local status="$4"
	local message="$5"
	local data="${6:-{}}"
	if ! printf '%s\n' "$data" | jq -e . >/dev/null 2>&1; then
		data="{}"
	fi
	jq -cn \
		--arg timestamp "$(timestamp)" \
		--arg run_id "$run_id" \
		--arg event "$event" \
		--arg status "$status" \
		--arg message "$message" \
		--argjson data "$data" \
		'{timestamp:$timestamp,run_id:$run_id,event:$event,status:$status,message:$message,data:$data}' \
		>> "$events_file"
}

create_runtime_envelope() {
	local run_dir="$1"
	local run_id="$2"
	local selected_adapter="$3"
	local selected="$4"
	local command_rel="$5"
	local request="$6"
	local requested_output="$7"
	local prompt_text="$8"
	local timeout_seconds="$9"
	local status_file="$run_dir/STATUS.json"
	local run_file="$run_dir/RUN.json"
	local events_file="$run_dir/events.jsonl"
	local artifacts_dir="$run_dir/artifacts"
	local handoff_file="$run_dir/HANDOFF.md"
	local started_at
	started_at="$(timestamp)"
	mkdir -p "$artifacts_dir" "$run_dir/children" "$run_dir/adapter-state"
	: > "$events_file"
	write_runtime_handoff "$handoff_file" "$selected" "$command_rel" "$request" "$requested_output" "$prompt_text" "$timeout_seconds"
	adapter_profile_json "$selected_adapter" > "$artifacts_dir/adapter-profile.json"
	jq -n \
		--arg run_id "$run_id" \
		--arg adapter_id "$selected_adapter" \
		--arg target_id "$selected" \
		--argjson timeout_seconds "$timeout_seconds" \
		'{
			schema_version:"arcanum.runtime.run.v1",
			run_id:$run_id,
			parent_run_id:null,
			orchestrator_id:"tools-arcanum",
			orchestrator_run_id:$run_id,
			adapter_id:$adapter_id,
			adapter_profile_path:"artifacts/adapter-profile.json",
			target_kind:"command",
			target_id:$target_id,
			loop_role:"root",
			loop_id:("arcanum-command-" + $target_id),
			parent_loop_id:null,
			stage_number:null,
			stage_name:null,
			handoff_path:"HANDOFF.md",
			status_path:"STATUS.json",
			result_path:null,
			events_path:"events.jsonl",
			artifacts_dir:"artifacts",
			children_dir:"children",
			adapter_state_dir:"adapter-state",
			execution_policy:{
				timeout_seconds:$timeout_seconds
			}
		}' > "$run_file"
	jq -n \
		--arg run_id "$run_id" \
		--arg started_at "$started_at" \
		'{
			schema_version:"arcanum.runtime.status.v1",
			run_id:$run_id,
			status:"running",
			adapter_status:"running",
			validation_grade:null,
			output_paths:[],
			blocked_reason:null,
			error_summary:null,
			started_at:$started_at,
			completed_at:null
		}' > "$status_file"
	write_envelope_event "$events_file" "$run_id" "created" "queued" "Runtime envelope created."
	write_envelope_event "$events_file" "$run_id" "adapter-started" "running" "Adapter started."
}

finish_runtime_envelope() {
	local run_dir="$1"
	local run_id="$2"
	local status="$3"
	local adapter_status="$4"
	local validation_grade="$5"
	local output_path="$6"
	local blocked_reason="${7:-}"
	local error_summary="${8:-}"
	local status_file="$run_dir/STATUS.json"
	local events_file="$run_dir/events.jsonl"
	local completed_at
	completed_at="$(timestamp)"
	jq -n \
		--arg run_id "$run_id" \
		--arg status "$status" \
		--arg adapter_status "$adapter_status" \
		--arg validation_grade "$validation_grade" \
		--arg output_path "$output_path" \
		--arg blocked_reason "$blocked_reason" \
		--arg error_summary "$error_summary" \
		--arg completed_at "$completed_at" \
		--slurpfile prior "$status_file" \
		'{
			schema_version:"arcanum.runtime.status.v1",
			run_id:$run_id,
			status:$status,
			adapter_status:$adapter_status,
			validation_grade:(if $validation_grade == "" then null else $validation_grade end),
			output_paths:(if $output_path == "" then [] else [$output_path] end),
			blocked_reason:(if $blocked_reason == "" then null else $blocked_reason end),
			error_summary:(if $error_summary == "" then null else $error_summary end),
			started_at:($prior[0].started_at // null),
			completed_at:$completed_at
		}' > "$status_file"
	case "$status" in
		passed|flagged)
			write_envelope_event "$events_file" "$run_id" "result-written" "$status" "Command output written."
			write_envelope_event "$events_file" "$run_id" "adapter-finished" "$status" "Adapter finished."
			;;
		blocked)
			write_envelope_event "$events_file" "$run_id" "blocked" "$status" "Adapter blocked." "$(jq -cn --arg reason "$blocked_reason" '{blocked_reason:$reason}')"
			;;
		failed)
			write_envelope_event "$events_file" "$run_id" "failed" "$status" "Adapter failed."
			;;
	esac
}

observe_result() {
	local selected="$1"
	local command_rel="$2"
	local request="$3"
	local status="$4"
	local output_rel="$5"
	local command_abs kind capability_id capability_tier capability_alias run_id run_dir envelope timestamp recommendation strict_mode
	strict_mode="${OBSERVED_INVOCATION_STRICT:-0}"

	if [[ ! -x "$observer" || ! -d "$observability_dir" ]] || ! command -v jq >/dev/null 2>&1; then
		printf 'OBSERVATION=skipped\n'
		printf 'REASON=observer unavailable\n'
		if [[ "$strict_mode" == "1" ]]; then
			return 1
		fi
		return 0
	fi

	command_abs="$repo_root/$command_rel"
	kind="$(detect_kind "$command_abs" "$selected")"
	capability_id="$(detect_capability_id "$command_abs" "$selected")"
	capability_tier="$(detect_tier "$command_abs")"
	capability_alias="$(detect_alias "$command_abs" "$selected")"
	timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	run_id="arcanum-command-$selected-$(date -u +%Y%m%dT%H%M%SZ)"
	run_dir="$observability_dir/runs/arcanum-command/$run_id"
	envelope="$run_dir/envelope.json"
	mkdir -p "$run_dir"
	recommendation="none"
	if [[ "$status" != "completed" ]]; then
		recommendation="inspect-run"
	fi

	jq -n \
		--arg timestamp "$timestamp" \
		--arg run_id "$run_id" \
		--arg selected "$selected" \
		--arg capability_id "$capability_id" \
		--arg kind "$kind" \
		--arg capability_tier "$capability_tier" \
		--arg capability_alias "$capability_alias" \
		--arg command_rel "$command_rel" \
		--arg request "$request" \
		--arg status "$status" \
		--arg output "$output_rel" \
		--arg recommendation "$recommendation" \
		'{
			timestamp: $timestamp,
			run_id: $run_id,
			session_id: "arcanum-command-surface",
			sigil: $capability_id,
			tier: $capability_tier,
			mode: "command",
			capability: {
				id: $capability_id,
				kind: $kind,
				tier: $capability_tier,
				mode: "command",
				alias: (if $capability_alias == "" then null else $capability_alias end)
			},
			command: {
				name: $selected,
				file: $command_rel
			},
			request: {
				raw: $request,
				summary: ("Arcanum command " + $selected),
				intent: $request
			},
			execution: {
				status: $status,
				outputs: (if $output == "" then [] else [$output] end),
				files_changed: [],
				validation: ["arcanum command surface dispatch", "tools/arcanum deterministic observer envelope"],
				notes: ("command=" + $command_rel)
			},
			observer: {
				quality_bar_status: (if $status == "completed" then "pass" else "partial" end),
				anti_pattern_hits: [],
				workflow_gaps: [],
				output_contract_drift: false,
				reflection_trigger: "none",
				recommendation: $recommendation
			},
			target_artifact: $command_rel
		}' > "$envelope"

	observe_output="$("$observer" --envelope "$envelope" --observability-dir "$observability_dir" 2>&1 || true)"
	printf '%s\n' "$observe_output"
	if ! printf '%s\n' "$observe_output" | grep -q '^OBSERVATION=\(recorded\|skipped\)'; then
		if [[ "$strict_mode" == "1" ]]; then
			return 1
		fi
		printf 'REFLECTION=skipped\n'
		printf 'REASON=observation-failed\n'
		printf 'REPORT=n/a\n'
		return 0
	fi

	recommendation="$(printf '%s\n' "$observe_output" | sed -n 's/^RECOMMENDATION=//p' | tail -n 1)"
	reflection_mode="${OBSERVED_REFLECT:-auto}"
	case "$reflection_mode" in
		off)
			printf 'REFLECTION=skipped\n'
			printf 'REASON=reflection-disabled\n'
			printf 'REPORT=n/a\n'
			;;
		auto)
			if [[ "$recommendation" == "reflect-now" && -x "$reflector" ]]; then
				"$reflector" --capability "$capability_id" --kind "$kind" --observability-dir "$observability_dir"
			else
				printf 'REFLECTION=skipped\n'
				printf 'REASON=no-recommendation\n'
				printf 'REPORT=n/a\n'
			fi
			;;
		always)
			if [[ -x "$reflector" ]]; then
				"$reflector" --capability "$capability_id" --kind "$kind" --observability-dir "$observability_dir"
			else
				printf 'REFLECTION=failed\n'
				printf 'REASON=reflector-unavailable\n'
				printf 'REPORT=n/a\n'
			fi
			;;
		*)
			printf 'REFLECTION=failed\n'
			printf 'REASON=invalid OBSERVED_REFLECT: %s\n' "$reflection_mode"
			printf 'REPORT=n/a\n'
			;;
	esac
}

if [[ "$#" -eq 0 ]]; then
	usage >&2
	exit 2
fi

while [[ "$#" -gt 0 ]]; do
	case "$1" in
		--help|-h)
			usage
			exit 0
			;;
		--list)
			if [[ ! -d "$commands_dir" && ! -d "$native_skills_dir" ]]; then
				printf 'ERROR: command or skill directory not found: %s or %s\n' "${commands_dir#$repo_root/}" "${native_skills_dir#$repo_root/}" >&2
				exit 1
			fi
			{
				if [[ -d "$commands_dir" ]]; then
					find "$commands_dir" -maxdepth 1 -type f -name '*.md' -printf '%f\n' | sed 's/\.md$//'
				fi
				if [[ -d "$native_skills_dir" ]]; then
					find "$native_skills_dir" -mindepth 2 -maxdepth 2 -type f -name 'SKILL.md' -printf '%h\n' | xargs -r -n 1 basename
				fi
			} | sort -u
			exit 0
			;;
		--list-adapters)
			list_adapters
			exit 0
			;;
		--resolve-adapter)
			mode="resolve-adapter"
			shift
			if [[ "$#" -eq 0 ]]; then
				usage >&2
				exit 2
			fi
			adapter_id="$1"
			shift
			break
			;;
		--get-default-adapter)
			mode="get-default-adapter"
			shift
			break
			;;
		--set-default-adapter)
			mode="set-default-adapter"
			shift
			if [[ "$#" -eq 0 ]]; then
				usage >&2
				exit 2
			fi
			adapter_id="$1"
			shift
			break
			;;
		--resolve)
			mode="resolve"
			shift
			if [[ "$#" -eq 0 ]]; then
				usage >&2
				exit 2
			fi
			command_name="$(normalize_command "$1")"
			shift
			break
			;;
		--print-prompt)
			mode="prompt"
			shift
			;;
		--exec)
			mode="exec"
			shift
			;;
		--adapter)
			adapter_id="$2"
			adapter_explicit="true"
			shift 2
			;;
			--output)
				output_path="$2"
				shift 2
				;;
			--timeout)
				if [[ "$#" -lt 2 ]]; then
					printf 'ERROR: --timeout requires seconds\n' >&2
					usage >&2
					exit 2
				fi
				runtime_timeout_seconds="$2"
				shift 2
				;;
		--)
			shift
			break
			;;
		-*)
			printf 'ERROR: unknown option: %s\n' "$1" >&2
			usage >&2
			exit 2
			;;
		*)
			command_name="$(normalize_command "$1")"
			shift
			break
			;;
	esac
done

if [[ "$mode" == "resolve-adapter" ]]; then
	resolve_adapter "$adapter_id"
	exit 0
fi

if [[ "$mode" == "get-default-adapter" ]]; then
	default_adapter="$(get_default_adapter)"
	if [[ -z "$default_adapter" ]]; then
		printf 'DEFAULT_ADAPTER=none\n'
	else
		printf 'DEFAULT_ADAPTER=%s\n' "$default_adapter"
	fi
	if [[ -f "$runtime_config_file" ]]; then
		printf 'CONFIG=%s\n' "${runtime_config_file#$repo_root/}"
	else
		printf 'CONFIG=implicit\n'
	fi
	exit 0
fi

if [[ "$mode" == "set-default-adapter" ]]; then
	set_default_adapter "$adapter_id"
	exit 0
fi

if [[ -z "$command_name" ]]; then
	if [[ "$#" -eq 0 ]]; then
		usage >&2
		exit 2
	fi
	command_name="$(normalize_command "$1")"
	shift
fi

command_rel="$(resolve_command "$command_name" || true)"
if [[ -z "$command_rel" ]]; then
	printf 'ERROR: unknown Arcanum command: %s\n' "$command_name" >&2
	printf 'Try: tools/arcanum --list\n' >&2
	exit 1
fi

if [[ "$mode" == "resolve" ]]; then
	printf 'COMMAND=%s\n' "$command_name"
	printf 'COMMAND_FILE=%s\n' "$command_rel"
	exit 0
fi

request="$*"
prompt="$(build_prompt "$command_name" "$command_rel" "$request")"

if [[ "$mode" == "prompt" ]]; then
	printf '%s\n' "$prompt"
	exit 0
fi

if [[ -z "$output_path" ]]; then
	run_stamp="$(date -u +%Y%m%dT%H%M%SZ)"
	output_path=".arcanum/observability/runs/arcanum-command/$run_stamp-$command_name/output.md"
fi
output_abs="$(path_abs "$output_path")"
mkdir -p "$(dirname "$output_abs")"

if [[ -z "$adapter_id" ]]; then
	adapter_id="$(get_default_adapter)"
fi
if [[ -z "$adapter_id" ]]; then
		adapter_id="native-skill"
fi
if ! adapter_exists "$adapter_id"; then
	printf 'ERROR: unknown runtime adapter: %s\n' "$adapter_id" >&2
	printf 'Try: tools/arcanum --list-adapters\n' >&2
	exit 1
fi
if [[ ! "$runtime_timeout_seconds" =~ ^[0-9]+$ ]]; then
	printf 'ERROR: --timeout must be a non-negative integer number of seconds\n' >&2
	exit 2
fi

run_stamp="$(date -u +%Y%m%dT%H%M%SZ)"
runtime_envelope_enabled="${ARCANUM_RUNTIME_ENVELOPE:-0}"
if [[ "${ARCANUM_RUNTIME_RUNNER:-0}" == "1" ]]; then
	runtime_envelope_enabled="1"
fi
runtime_run_dir=""
runtime_run_id="arcanum-command-$command_name-$run_stamp"
if [[ "$runtime_envelope_enabled" == "1" ]]; then
	if ! command -v jq >/dev/null 2>&1; then
		printf 'ERROR: jq is required for runtime envelope evidence\n' >&2
		exit 1
	fi
	if [[ -n "${ARCANUM_RUNTIME_RUN_DIR:-}" ]]; then
		runtime_run_dir="$(path_abs "$ARCANUM_RUNTIME_RUN_DIR")"
		runtime_run_id="$(basename "$runtime_run_dir")"
	else
		runtime_run_dir="$repo_root/.arcanum/runtime/runs/$runtime_run_id"
	fi
	create_runtime_envelope "$runtime_run_dir" "$runtime_run_id" "$adapter_id" "$command_name" "$command_rel" "$request" "$output_path" "$prompt" "$runtime_timeout_seconds"
fi

status="completed"
runtime_status="passed"
runtime_adapter_status="passed"
runtime_validation_grade="execution"
runtime_blocked_reason=""
runtime_error_summary=""
adapter_log=""
codex_exit=0

if [[ "$command_name" == "refine" && ( "$adapter_id" == "native-skill" || "$adapter_id" == "codex-skill" || "$adapter_id" == "local-skill" || "$adapter_id" == "codex-exec" ) && "${ARCANUM_REFINE_NATIVE:-1}" != "0" ]]; then
	run_native_refine "$request" "$output_abs" "$run_stamp"
	runtime_validation_grade="refine-native"
else
case "$adapter_id" in
	native-skill|codex-skill|claude-skill|copilot-instructions|local-skill)
		runtime_status="flagged"
		runtime_adapter_status="flagged"
		runtime_validation_grade="contract"
		cat > "$output_abs" <<LOCALSKILL
# Arcanum Runtime-Native Handoff

STATUS: flag

The \`$adapter_id\` adapter does not spawn a nested model-backed CLI process. It preserves the command prompt, requested output path, and receipt contract so the parent native runtime surface can execute the stage directly.

## Command

- Command: \`$command_name\`
- Command file: \`$command_rel\`
- Output: \`$output_path\`
- Adapter: \`$adapter_id\`

## Request

$request

## Stage Receipt Handoff

- run_id: \`${ARCANUM_STAGE_RUN_ID:-n/a}\`
- stage: \`${ARCANUM_STAGE_TITLE:-n/a}\`
- owner: \`${ARCANUM_STAGE_OWNER:-$command_name}\`
- handoff_path: \`${ARCANUM_STAGE_HANDOFF_PATH:-$output_path}\`
- expected_receipt_path: \`${ARCANUM_STAGE_EXPECTED_RECEIPT_PATH:-n/a}\`
- resume_command: \`${ARCANUM_STAGE_RESUME_COMMAND:-n/a}\`

### Stage Request

\`\`\`text
${ARCANUM_STAGE_REQUEST:-$request}
\`\`\`

## Receipt Contract

The parent runner or subagent must return:

- \`dispatch_id\` or run id when available
- \`step_id\` or command name
- \`capability_ref\`: \`$command_name\`
- \`execution_surface\`: \`codex-skill\`, \`claude-skill\`, \`copilot-instructions\`, \`native-subagent\`, or \`local-inline\`
- \`status\`: \`pass\`, \`flag\`, \`block\`, \`interrupted\`, or \`timeout\`
- artifact paths
- validation result
- observability status or returned telemetry receipt
- blockers and handoff note

## Prompt

\`\`\`markdown
$prompt
\`\`\`
LOCALSKILL
		;;
	dry-run)
		cat > "$output_abs" <<DRYRUN
# Arcanum Dry Run

PASS: dry-run adapter selected.

- Command: $command_name
- Command file: $command_rel
- Output: $output_path
- Request: $request
DRYRUN
		runtime_validation_grade="contract"
		;;
		codex-exec|codex-bypass)
			codex_bin="$(find_codex || true)"
			if [[ -z "$codex_bin" ]]; then
			status="failed"
			runtime_status="blocked"
			runtime_adapter_status="blocked"
			runtime_validation_grade="adapter-safety"
			runtime_blocked_reason="codex-binary-missing"
			runtime_error_summary="Codex executable was not found."
			cat > "$output_abs" <<BLOCK
# Command Result

BLOCK: codex-binary-missing

Codex executable was not found. Set CODEX_BIN to the codex executable path.
BLOCK
			else
				if [[ "$runtime_envelope_enabled" == "1" ]]; then
					adapter_log="$runtime_run_dir/artifacts/codex-exec.log"
				else
				adapter_log="$(mktemp "${TMPDIR:-/tmp}/arcanum-codex-exec-log-XXXXXX")"
			fi
				set +e
				if [[ "$runtime_timeout_seconds" -gt 0 ]] && command -v timeout >/dev/null 2>&1; then
					if [[ "$adapter_id" == "codex-bypass" ]]; then
						timeout --kill-after=30s "${runtime_timeout_seconds}s" \
							"$codex_bin" exec \
							-C "$repo_root" \
							--dangerously-bypass-approvals-and-sandbox \
							--ignore-user-config \
							--ignore-rules \
							--output-last-message "$output_abs" \
							"$prompt" >"$adapter_log" 2>&1
					else
						timeout --kill-after=30s "${runtime_timeout_seconds}s" \
							"$codex_bin" exec \
							-C "$repo_root" \
							--sandbox workspace-write \
							--output-last-message "$output_abs" \
							"$prompt" >"$adapter_log" 2>&1
					fi
				else
					if [[ "$adapter_id" == "codex-bypass" ]]; then
							"$codex_bin" exec \
							-C "$repo_root" \
							--dangerously-bypass-approvals-and-sandbox \
							--ignore-user-config \
							--ignore-rules \
							--output-last-message "$output_abs" \
							"$prompt" >"$adapter_log" 2>&1
					else
						"$codex_bin" exec \
							-C "$repo_root" \
							--sandbox workspace-write \
							--output-last-message "$output_abs" \
							"$prompt" >"$adapter_log" 2>&1
					fi
				fi
			codex_exit="$?"
			set -e
			if [[ "$codex_exit" -eq 0 && -s "$output_abs" ]] && grep -Eiq '(^|\n)[[:space:]]*(BLOCK:|Blocked before task zero|I could not|cannot safely execute|bubblewrap is unavailable)' "$output_abs"; then
				status="failed"
				runtime_status="blocked"
				runtime_adapter_status="blocked"
				runtime_validation_grade="adapter-safety"
				runtime_blocked_reason="codex-output-reported-block"
				runtime_error_summary="Codex produced an output, but the output reports a blocked command execution. See $(rel_path "$output_abs")."
			elif [[ "$codex_exit" -eq 124 || "$codex_exit" -eq 137 ]]; then
				status="failed"
				runtime_status="blocked"
				runtime_adapter_status="blocked"
				runtime_validation_grade="adapter-timeout"
				runtime_blocked_reason="$adapter_id-timeout"
				runtime_error_summary="Codex exceeded the configured timeout of ${runtime_timeout_seconds}s. Rerun with --timeout <seconds> or ARCANUM_EXEC_TIMEOUT_SECONDS."
				if [[ ! -s "$output_abs" ]]; then
					cat > "$output_abs" <<BLOCK
# Command Result

BLOCK: $adapter_id-timeout

Codex exceeded the configured timeout of ${runtime_timeout_seconds}s.

Rerun with a larger timeout, for example:

\`\`\`bash
tools/arcanum --exec --timeout 3600 $command_name "$request"
\`\`\`
BLOCK
				fi
			elif [[ "$codex_exit" -ne 0 || ! -s "$output_abs" ]]; then
				status="failed"
				if [[ ! -s "$output_abs" ]]; then
					cat > "$output_abs" <<BLOCK
# Command Result

BLOCK: $adapter_id did not produce command output.

See $(rel_path "$adapter_log").
BLOCK
				fi
				if grep -Eiq 'readonly database|read-only database|failed to initialize state runtime|failed to open state db' "$adapter_log"; then
					runtime_status="blocked"
					runtime_adapter_status="blocked"
					runtime_validation_grade="adapter-safety"
					runtime_blocked_reason="codex-state-unavailable"
					runtime_error_summary="Codex could not initialize its local state database in this environment. See $(rel_path "$adapter_log")."
				elif grep -Eiq 'bubblewrap is unavailable|no system bwrap|codex-resources/bwrap' "$adapter_log"; then
					runtime_status="blocked"
					runtime_adapter_status="blocked"
					runtime_validation_grade="adapter-safety"
					runtime_blocked_reason="codex-sandbox-unavailable"
					runtime_error_summary="Codex could not start its sandboxed shell tools in this environment. See $(rel_path "$adapter_log")."
				elif grep -Eiq 'network|backend|connection|request|api|auth|login|unauthorized|forbidden|read-only file system|failed to initialize' "$adapter_log"; then
					runtime_status="blocked"
					runtime_adapter_status="blocked"
					runtime_validation_grade="adapter-safety"
					runtime_blocked_reason="codex-backend-or-auth-unavailable"
					runtime_error_summary="Codex exited before a clean result could be produced. See $(rel_path "$adapter_log")."
				else
					runtime_status="failed"
					runtime_adapter_status="failed"
					runtime_validation_grade="adapter-safety"
					runtime_error_summary="Codex process exited nonzero after invocation. See $(rel_path "$adapter_log")."
				fi
			fi
		fi
		;;
esac
fi

if [[ "$runtime_envelope_enabled" == "1" ]]; then
	finish_runtime_envelope "$runtime_run_dir" "$runtime_run_id" "$runtime_status" "$runtime_adapter_status" "$runtime_validation_grade" "$(rel_path "$output_abs")" "$runtime_blocked_reason" "$runtime_error_summary"
fi

printf 'COMMAND=%s\n' "$command_name"
printf 'COMMAND_FILE=%s\n' "$command_rel"
printf 'ADAPTER=%s\n' "$adapter_id"
printf 'OUTPUT=%s\n' "$output_path"
printf 'TIMEOUT_SECONDS=%s\n' "$runtime_timeout_seconds"
if [[ -n "$runtime_run_dir" ]]; then
	printf 'RUNTIME_RUN=%s\n' "${runtime_run_dir#$repo_root/}"
	printf 'RUNTIME_STATUS=%s\n' "$runtime_status"
fi
observe_result "$command_name" "$command_rel" "$request" "$status" "$output_path"

if [[ "$status" != "completed" ]]; then
	exit 1
fi
