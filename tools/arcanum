	dispatch_rel="$(rel_path "$dispatch")"
	local result_rel
	result_rel="$(rel_path "$run_dir/RESULT.md")"
	local template="$repo_root/arcana/refine/templates/refine-dispatch.json"
	if [[ ! -f "$template" ]]; then
		printf 'block: missing arcana/refine/templates/refine-dispatch.json'
		return 0
	fi
	jq \
		--arg run_id "$run_id" \
		--arg request "$request" \
		--arg target "$target" \
		--arg result "$result_rel" \
		--arg research "$research" \
		'
		def replace_placeholders:
			walk(if type == "string" then
				gsub("<run-id>"; $run_id)
				| gsub("<operator request>"; $request)
				| gsub("<target>"; $target)
			else . end);
		replace_placeholders
		| .dispatch_id = $run_id
		| .intent.raw = $request
		| .intent.objective = ("Run the canonical Refine loop for " + $target + " and produce RESULT.md.")
		| .intent.target_artifact = $result
		| .intent.operator_sentence = $request
		| .route_menu.selected_item_id = "baseline_sequence"
		| .subagent_strategy.status = "none"
		| .subagent_strategy.trigger = "Native root Refine run uses the canonical local sequence without delegated sibling agents."
		| .subagent_strategy.explanation = "No subagents are used for this native local validation run; stages are dispatched through the configured runtime adapter boundary."
		| .subagent_strategy.context = [$target, $request]
		| .subagent_strategy.roles = []
		| .subagent_strategy.parallelism = "none"
		| .subagent_strategy.join_policy = "none"
		| .subagent_strategy.authorization = "not_needed"
		| .subagent_strategy.permission_prompt = "No subagents are requested for this native local Refine run."
		| .subagent_strategy.receipt_requirements = []
		| (.steps[] | select(.step_id == "s04-research-decision") | .mode) = $research
		' "$template" > "$dispatch"
	local validator="$repo_root/formulae/dispatch-spec/scripts/validate-dispatch.py"
	if [[ ! -x "$validator" && ! -f "$validator" ]]; then
		printf 'block: missing formulae/dispatch-spec/scripts/validate-dispatch.py'
		return 0
	fi
	local validation_output
	if validation_output="$(python3 "$validator" "$dispatch" 2>&1)"; then
		printf 'pass'
	else
		printf 'block: %s' "$validation_output" > "$run_dir/REFINE-DISPATCH.validation.log"
		printf 'block'
	fi
}

