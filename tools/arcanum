#!/usr/bin/env bash
set -euo pipefail

usage() {
	cat <<'USAGE'
Usage:
  tools/arcanum --list
  tools/arcanum --resolve <command>
  tools/arcanum --list-adapters
  tools/arcanum --resolve-adapter <adapter-id>
  tools/arcanum --get-default-adapter
  tools/arcanum --set-default-adapter <adapter-id>
  tools/arcanum [--print-prompt] <command> [arguments...]
  tools/arcanum --exec [--adapter <adapter-id>] [--output <path>] [--timeout <seconds>] <command> [arguments...]

Examples:
  tools/arcanum /invoke define a cache invalidation sigil
  tools/arcanum /invoke refresh with REFRESH-REPORT.md from latest session evidence
  tools/arcanum --exec invoke define a cache invalidation sigil
  tools/arcanum --exec --timeout 1800 refine run a bounded refinement loop
  tools/arcanum --exec --adapter codex-skill invoke define a cache invalidation sigil
  tools/arcanum --exec --adapter claude-skill invoke define a cache invalidation sigil
  tools/arcanum --exec --adapter copilot-instructions invoke define a cache invalidation sigil
  tools/arcanum --exec --adapter dry-run invoke define a cache invalidation sigil
  tools/arcanum --resolve interrogation
  tools/arcanum --list-adapters

This is the repository-local Arcanum command surface. It accepts bare aliases
such as invoke and slash-like aliases such as /invoke, resolves them through
.codex/commands, and can prepare or run the selected command through a runtime
adapter. Runtime-native adapters emit handoff and receipt contracts; legacy
model CLI adapters are explicit opt-in.
USAGE
}

script_path="${BASH_SOURCE[0]}"
script_dir="$(cd "$(dirname "$script_path")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
commands_dir="$repo_root/.codex/commands"
native_skills_dir="$repo_root/.agents/skills"
observability_dir="$repo_root/.arcanum/observability"
runtime_config_file="$repo_root/.arcanum/runtime/config.json"
runtime_adapters_dir="$repo_root/.arcanum/runtime/adapters"
observer="$repo_root/framework/observability/scripts/observe-invocation.sh"
reflector="$repo_root/framework/observability/scripts/reflect-invocation-signals.sh"
source_codex_home="${ARCANUM_SOURCE_CODEX_HOME:-${CODEX_HOME:-$HOME/.codex}}"

mode="prompt"
output_path=""
command_name=""
adapter_id="${ARCANUM_RUNTIME_ADAPTER:-}"
adapter_explicit="false"
runtime_timeout_seconds="${ARCANUM_EXEC_TIMEOUT_SECONDS:-${ARCANUM_CODEX_EXEC_TIMEOUT_SECONDS:-1800}}"

timestamp() {
	date -u +%Y-%m-%dT%H:%M:%SZ
}

path_abs() {
	local path="$1"
	if [[ "$path" == /* ]]; then
		printf '%s\n' "$path"
	else
		printf '%s\n' "$repo_root/$path"
	fi
}

rel_path() {
	local path="$1"
	case "$path" in
		"$repo_root"/*) printf '%s\n' "${path#$repo_root/}" ;;
		*) printf '%s\n' "$path" ;;
	esac
}

adapter_exists() {
	case "$1" in
		native-skill|codex-skill|claude-skill|copilot-instructions|local-skill|dry-run|codex-exec|codex-bypass) return 0 ;;
		*) return 1 ;;
	esac
}

adapter_profile_json() {
	local selected_adapter="$1"
	case "$selected_adapter" in
		native-skill|codex-skill|claude-skill|copilot-instructions|local-skill)
			local runtime_kind="native-agent-skill-surface"
			local package_shape="host-inferred native skill or instruction package"
			local alias_note=""
			case "$selected_adapter" in
				native-skill)
					runtime_kind="abstract-native-runtime-selector"
					package_shape="selected host-native package"
					;;
				codex-skill)
					package_shape="\$CODEX_HOME/skills/<name>/SKILL.md"
					;;
				claude-skill)
					package_shape=".claude/skills/<name>/SKILL.md plus optional .claude/agents/<name>.md"
					;;
				copilot-instructions)
					package_shape=".github/skills/<name>/SKILL.md plus .github/instructions/*.instructions.md"
					;;
				local-skill)
					runtime_kind="compatibility-alias"
					package_shape="\$CODEX_HOME/skills/<name>/SKILL.md"
					alias_note="Compatibility alias for codex-skill while older artifacts are migrated."
					;;
			esac
			jq -n \
				--arg adapter_id "$selected_adapter" \
				--arg runtime_kind "$runtime_kind" \
				--arg package_shape "$package_shape" \
				--arg alias_note "$alias_note" \
				'{
					adapter_id:$adapter_id,
					runtime_kind:$runtime_kind,
					execution_mode:"parent-orchestrated-handoff",
					state_model:"current-session-and-native-runtime",
					isolation_model:"no-nested-model-cli",
					input_shape:"command-prompt-plus-dispatch-step",
					output_shape:"artifact-plus-stage-receipt",
					failure_model:"passed|flagged|blocked|interrupted|timeout",
					package_shape:$package_shape,
					alias_note:(if $alias_note == "" then null else $alias_note end),
					capabilities:["represent native runtime execution without spawning nested model CLI","return handoff and receipt requirements for parent orchestration","record canonical source and alias provenance for generated native packages"],
					limitations:["not callable as an autonomous shell-only model runtime","requires the parent runtime to own skill or agent execution and join"],
					validation_surface:["adapter profile evidence","dispatch-spec validation","stage receipt validation","observer or fallback telemetry receipt"]
				}'
			;;
		dry-run)
			jq -n \
				'{
					adapter_id:"dry-run",
					runtime_kind:"dry-run",
					execution_mode:"simulated",
					state_model:"stateless",
					isolation_model:"filesystem-output-only",
					input_shape:"command-prompt",
					output_shape:"requested-output",
					failure_model:"passed|blocked|failed",
					capabilities:["validate command-surface adapter dispatch without external execution"],
					limitations:["does not prove model-backed execution"],
					validation_surface:["tools/arcanum --exec --adapter dry-run","requested output exists"]
				}'
			;;
			codex-exec)
				jq -n \
					'{
						adapter_id:"codex-exec",
					runtime_kind:"model-backed-cli",
					execution_mode:"synchronous-process",
					state_model:"normal-codex-cli-state",
					isolation_model:"no-run-local-codex-home-by-default",
					input_shape:"command-prompt",
					output_shape:"requested-output",
					failure_model:"passed|flagged|blocked|failed",
					capabilities:["execute Codex CLI with an Arcanum command prompt","capture final output in the requested output path"],
					limitations:["does not use native /goal","does not own orchestrator semantics","does not create per-run private CLI state links by default"],
					timeout_control:"--timeout <seconds> or ARCANUM_EXEC_TIMEOUT_SECONDS; 0 disables the wrapper timeout",
						validation_surface:["adapter profile evidence","Codex CLI exit classification","timeout classification","STATUS.json validation_grade","events.jsonl closeout"]
					}'
				;;
			codex-bypass)
				jq -n \
					'{
						adapter_id:"codex-bypass",
						runtime_kind:"model-backed-cli",
						execution_mode:"synchronous-process",
						state_model:"normal-codex-cli-state",
						isolation_model:"codex-cli-danger-full-access",
						input_shape:"command-prompt",
						output_shape:"requested-output",
						failure_model:"passed|flagged|blocked|failed",
						capabilities:["execute Codex CLI with an Arcanum command prompt when workspace-write sandboxing is unavailable","capture final output in the requested output path"],
						limitations:["bypasses Codex CLI sandbox and approval prompts","intended only for externally trusted automation environments"],
						timeout_control:"--timeout <seconds> or ARCANUM_EXEC_TIMEOUT_SECONDS; 0 disables the wrapper timeout",
						validation_surface:["adapter profile evidence","Codex CLI exit classification","timeout classification","STATUS.json validation_grade","events.jsonl closeout"]
					}'
				;;
		*) return 1 ;;
	esac
}

list_adapters() {
	printf 'native-skill\n'
	printf 'codex-skill\n'
	printf 'claude-skill\n'
	printf 'copilot-instructions\n'
	printf 'local-skill\n'
	printf 'dry-run\n'
	printf 'codex-exec\n'
	printf 'codex-bypass\n'
}

resolve_adapter() {
	local selected_adapter="$1"
	if ! adapter_exists "$selected_adapter"; then
		printf 'ERROR: unknown runtime adapter: %s\n' "$selected_adapter" >&2
		return 1
	fi
	printf 'ADAPTER=%s\n' "$selected_adapter"
	printf 'PROFILE_SOURCE=static\n'
	adapter_profile_json "$selected_adapter"
}

infer_command_surface() {
	if [[ -d "$commands_dir" ]]; then
		printf 'codex\n'
	else
		printf 'none\n'
	fi
}

write_runtime_config() {
	local default_adapter="$1"
	local command_surface="$2"
	local default_json
	mkdir -p "$(dirname "$runtime_config_file")" "$runtime_adapters_dir"
	adapter_profile_json "native-skill" > "$runtime_adapters_dir/native-skill.json"
	adapter_profile_json "codex-skill" > "$runtime_adapters_dir/codex-skill.json"
	adapter_profile_json "claude-skill" > "$runtime_adapters_dir/claude-skill.json"
	adapter_profile_json "copilot-instructions" > "$runtime_adapters_dir/copilot-instructions.json"
	adapter_profile_json "local-skill" > "$runtime_adapters_dir/local-skill.json"
	adapter_profile_json "dry-run" > "$runtime_adapters_dir/dry-run.json"
	adapter_profile_json "codex-exec" > "$runtime_adapters_dir/codex-exec.json"
	adapter_profile_json "codex-bypass" > "$runtime_adapters_dir/codex-bypass.json"
	if [[ -z "$default_adapter" || "$default_adapter" == "none" || "$default_adapter" == "null" ]]; then
		default_json="null"
	else
		default_json="$(jq -Rn --arg value "$default_adapter" '$value')"
	fi
	jq -n \
		--arg command_surface "$command_surface" \
		--argjson default_adapter "$default_json" \
		'{
			schema_version:"arcanum.runtime.config.v1",
			command_surface:$command_surface,
			default_adapter:$default_adapter,
			adapters:{
					"native-skill":{enabled:true,profile_path:".arcanum/runtime/adapters/native-skill.json"},
					"codex-skill":{enabled:true,profile_path:".arcanum/runtime/adapters/codex-skill.json"},
					"claude-skill":{enabled:true,profile_path:".arcanum/runtime/adapters/claude-skill.json"},
					"copilot-instructions":{enabled:true,profile_path:".arcanum/runtime/adapters/copilot-instructions.json"},
					"local-skill":{enabled:true,profile_path:".arcanum/runtime/adapters/local-skill.json"},
					"codex-exec":{enabled:true,profile_path:".arcanum/runtime/adapters/codex-exec.json"},
					"codex-bypass":{enabled:true,profile_path:".arcanum/runtime/adapters/codex-bypass.json"},
					"dry-run":{enabled:true,profile_path:".arcanum/runtime/adapters/dry-run.json"}
			}
		}' > "$runtime_config_file"
}

get_default_adapter() {
	if [[ -f "$runtime_config_file" ]] && command -v jq >/dev/null 2>&1; then
		jq -r '.default_adapter // empty' "$runtime_config_file"
		return 0
	fi
	if [[ -d "$commands_dir" ]]; then
		printf 'codex-skill\n'
	fi
}

set_default_adapter() {
	local selected_adapter="$1"
	if ! adapter_exists "$selected_adapter"; then
		printf 'ERROR: unknown runtime adapter: %s\n' "$selected_adapter" >&2
		printf 'Try: tools/arcanum --list-adapters\n' >&2
		return 1
	fi
	if ! command -v jq >/dev/null 2>&1; then
		printf 'ERROR: jq is required to update runtime config\n' >&2
		return 1
	fi
	local command_surface
	command_surface="$(infer_command_surface)"
	if [[ -f "$runtime_config_file" ]]; then
		command_surface="$(jq -r '.command_surface // empty' "$runtime_config_file")"
		if [[ -z "$command_surface" ]]; then
			command_surface="$(infer_command_surface)"
		fi
	fi
	write_runtime_config "$selected_adapter" "$command_surface"
	printf 'DEFAULT_ADAPTER=%s\n' "$selected_adapter"
	printf 'CONFIG=%s\n' "${runtime_config_file#$repo_root/}"
}

find_codex() {
	if [[ -n "${CODEX_BIN:-}" && -x "${CODEX_BIN:-}" ]]; then
		printf '%s\n' "$CODEX_BIN"
		return 0
	fi
	if command -v codex >/dev/null 2>&1; then
		command -v codex
		return 0
	fi
	local candidate
	for candidate in \
		"$HOME/.vscode-server/extensions/openai.chatgpt-"*/bin/linux-x86_64/codex \
		"$HOME/.vscode/extensions/openai.chatgpt-"*/bin/linux-x86_64/codex \
		"$HOME/.local/bin/codex" \
		"$HOME/bin/codex"; do
		if [[ -x "$candidate" ]]; then
			printf '%s\n' "$candidate"
			return 0
		fi
	done
	return 1
}

normalize_command() {
	local raw="$1"
	raw="${raw#/}"
	printf '%s' "$raw"
}

frontmatter_value() {
	local source_file="$1"
	local key="$2"
	awk -v key="$key" '
		NR == 1 && $0 == "---" { in_fm=1; next }
		in_fm && $0 == "---" { exit }
		in_fm {
			prefix=key ":"
			if (index($0, prefix) == 1) {
				value=substr($0, length(prefix) + 1)
				gsub(/^[ \t]+|[ \t]+$/, "", value)
				gsub(/^"|"$/, "", value)
				print value
				exit
			}
		}
	' "$source_file"
}

capability_id_from_skill_file() {
	local skill_file="$1"
	local package_name canonical_source alias_of name_value
	package_name="$(basename "$(dirname "$skill_file")")"
	alias_of="$(frontmatter_value "$skill_file" "alias_of")"
	if [[ -n "$alias_of" && "$alias_of" != "null" ]]; then
		printf '%s' "${alias_of#arcanum-}"
		return 0
	fi
	name_value="$(frontmatter_value "$skill_file" "name")"
	if [[ -n "$name_value" ]]; then
		printf '%s' "${name_value#arcanum-}"
		return 0
	fi
	canonical_source="$(frontmatter_value "$skill_file" "canonical_source")"
	case "$canonical_source" in
		formulae/*/SKILL.md|transmutations/*/SKILL.md|arcana/*/SKILL.md)
			printf '%s' "$(basename "$(dirname "$canonical_source")")"
			return 0
			;;
		spells/*/README.md)
			printf '%s' "$(basename "$(dirname "$canonical_source")")"
			return 0
			;;
	esac
	printf '%s' "${package_name#arcanum-}"
}

detect_kind_from_skill_file() {
	local skill_file="$1"
	local canonical_source
	canonical_source="$(frontmatter_value "$skill_file" "canonical_source")"
	case "$canonical_source" in
		formulae/*/SKILL.md|transmutations/*/SKILL.md|arcana/*/SKILL.md) printf 'sigil' ;;
		spells/*/README.md) printf 'spell' ;;
		*) printf 'skill' ;;
	esac
}

detect_tier_from_skill_file() {
	local skill_file="$1"
	local tier canonical_source
	tier="$(frontmatter_value "$skill_file" "tier")"
	if [[ -n "$tier" ]]; then
		printf '%s' "$tier"
		return 0
	fi
	canonical_source="$(frontmatter_value "$skill_file" "canonical_source")"
	case "$canonical_source" in
		formulae/*) printf 'formulae' ;;
		transmutations/*) printf 'transmutations' ;;
		arcana/*) printf 'arcana' ;;
		spells/*) printf 'spell' ;;
		*) printf 'runtime' ;;
	esac
}

detect_alias_from_skill_file() {
	local skill_file="$1"
	local alias_of package_name capability_id
	alias_of="$(frontmatter_value "$skill_file" "alias_of")"
	[[ -n "$alias_of" && "$alias_of" != "null" ]] || return 0
	package_name="$(basename "$(dirname "$skill_file")")"
	capability_id="$(capability_id_from_skill_file "$skill_file")"
	if [[ "$package_name" != "$capability_id" ]]; then
		printf '%s' "$package_name"
	fi
}

detect_kind() {
	local command_file="$1"
	local command_name="$2"
	local marked
	if [[ "$command_file" == "$native_skills_dir"/* ]]; then
		detect_kind_from_skill_file "$command_file"
		return 0
	fi
	marked="$(sed -n 's/^<!-- arcanum:capability-kind \(.*\) -->$/\1/p' "$command_file" | head -n 1)"
	if [[ -n "$marked" ]]; then
		printf '%s' "$marked"
		return 0
	fi
	case "$command_name" in
		arcanum-sigil-*) printf 'sigil' ;;
		arcanum-spell-*) printf 'spell' ;;
		arcanum-necronomicon|arcanum-ontology-harness) printf 'spell' ;;
		*) printf 'skill' ;;
	esac
}

detect_capability_id() {
	local command_file="$1"
	local command_name="$2"
	local marked
	if [[ "$command_file" == "$native_skills_dir"/* ]]; then
		capability_id_from_skill_file "$command_file"
		return 0
	fi
	marked="$(sed -n 's/^<!-- arcanum:capability-id \(.*\) -->$/\1/p' "$command_file" | head -n 1)"
	if [[ -n "$marked" ]]; then
		printf '%s' "$marked"
		return 0
	fi
	case "$command_name" in
		arcanum-sigil-*) printf '%s' "${command_name#arcanum-sigil-}" ;;
		arcanum-spell-*) printf '%s' "${command_name#arcanum-spell-}" ;;
		arcanum-necronomicon) printf 'necronomicon' ;;
		arcanum-ontology-harness) printf 'ontology-harness' ;;
		*) printf '%s' "$command_name" ;;
	esac
}

detect_tier() {
	local command_file="$1"
	local marked
	if [[ "$command_file" == "$native_skills_dir"/* ]]; then
		detect_tier_from_skill_file "$command_file"
		return 0
	fi
	marked="$(sed -n 's/^<!-- arcanum:capability-tier \(.*\) -->$/\1/p' "$command_file" | head -n 1)"
	if [[ -n "$marked" ]]; then
		printf '%s' "$marked"
	else
		printf 'runtime'
	fi
}

detect_alias() {
	local command_file="$1"
	local command_name="$2"
	local marked
	if [[ "$command_file" == "$native_skills_dir"/* ]]; then
		detect_alias_from_skill_file "$command_file"
		return 0
	fi
	marked="$(sed -n 's/^<!-- arcanum:capability-alias \(.*\) -->$/\1/p' "$command_file" | head -n 1)"
	if [[ -n "$marked" ]]; then
		printf '%s' "$marked"
	elif [[ "$command_name" == "interrogation" ]]; then
		printf 'interrogation'
	fi
}

resolve_command() {
	local selected="$1"
	local command_file="$commands_dir/$selected.md"
	local skill_file="$native_skills_dir/$selected/SKILL.md"
	if [[ -f "$command_file" ]]; then
		printf '%s\n' "${command_file#$repo_root/}"
		return 0
	fi
	if [[ -f "$skill_file" ]]; then
		printf '%s\n' "${skill_file#$repo_root/}"
		return 0
	fi
	return 1
}

build_prompt() {
	local selected="$1"
	local adapter_rel="$2"
	local request="$3"
	cat <<PROMPT
Execute the already-dispatched Arcanum command \`$selected\`.

1. Read \`$adapter_rel\`.
2. Follow that command's process and embedded canonical contract.
3. Treat the user request below as the command arguments.
4. Treat observer envelope setup as task zero.
5. Preserve the command output contract and include observability closeout status when available.
6. Do not call \`tools/arcanum --exec\`, \`codex exec\`, or any nested model-backed runtime for this same command. This process is already the command-backed stage execution; produce the command artifact directly.

User request:
$request
PROMPT
}

trim_ws() {
	local value="$1"
	value="${value#"${value%%[![:space:]]*}"}"
	value="${value%"${value##*[![:space:]]}"}"
	printf '%s' "$value"
}

slugify() {
	local value="$1"
	value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g')"
	if [[ -z "$value" ]]; then
		value="target"
	fi
	printf '%s' "$value"
}

extract_request_value() {
	local request="$1"
	local key="$2"
	local value=""
	value="$(printf '%s\n' "$request" | sed -nE "s/(^|.*[;[:space:]])${key}=([^;]+).*/\2/p" | head -n 1)"
	trim_ws "$value"
}

extract_refine_target() {
	local request="$1"
	local target
	target="$(extract_request_value "$request" "target")"
	if [[ -n "$target" ]]; then
		printf '%s' "$target"
		return 0
	fi
	local token
	for token in $request; do
		case "$token" in
			--*|*=*) ;;
			*)
				printf '%s' "$token"
				return 0
				;;
		esac
	done
}

extract_refine_preset() {
	local request="$1"
	local preset
	preset="$(extract_request_value "$request" "preset")"
	if [[ -z "$preset" && "$request" =~ --preset[[:space:]]+([^[:space:];]+) ]]; then
		preset="${BASH_REMATCH[1]}"
	fi
	case "$preset" in
		compact|standard|full|deep) printf '%s' "$preset" ;;
		*) printf 'standard' ;;
	esac
}

extract_refine_research() {
	local request="$1"
	local research
	research="$(extract_request_value "$request" "research")"
	if [[ -z "$research" && "$request" =~ --research[[:space:]]+([^[:space:];]+) ]]; then
		research="${BASH_REMATCH[1]}"
	fi
	case "$research" in
		no|no-research) printf 'no-research' ;;
		bounded|bounded-research) printf 'bounded-research' ;;
		if-gap|research-if-gap-appears|"") printf 'research-if-gap-appears' ;;
		*) printf '%s' "$research" ;;
	esac
}

extract_existing_refine_run_dir() {
	local request="$1"
	local run_dir=""
	if [[ "$request" =~ use[[:space:]]+existing[[:space:]]+run[[:space:]]+folder[[:space:]]+([^;]+) ]]; then
		run_dir="${BASH_REMATCH[1]}"
	fi
	trim_ws "$run_dir"
}

resolve_refine_run_dir() {
	local target="$1"
	local request="$2"
	local run_stamp="$3"
	local explicit
	explicit="$(extract_existing_refine_run_dir "$request")"
	if [[ -n "$explicit" ]]; then
		path_abs "$explicit"
		return 0
	fi
	if [[ "$target" == *"/refinement-runs/"* ]]; then
		if [[ -d "$(path_abs "$target")" ]]; then
			path_abs "$target"
		else
			path_abs "$(dirname "$target")"
		fi
		return 0
	fi
	if [[ -d "$(path_abs "$target")" ]]; then
		path_abs "$target/development/refinement-runs/${run_stamp}-$(slugify "$(basename "$target")")"
		return 0
	fi
	if [[ -e "$(path_abs "$target")" ]]; then
		path_abs "$(dirname "$target")/development/refinement-runs/${run_stamp}-$(slugify "$(basename "$target")")"
		return 0
	fi
	path_abs ".arcanum/refinement-runs/${run_stamp}-$(slugify "$target")"
}

write_refine_block_stage() {
	local artifact="$1"
	local title="$2"
	local owner="$3"
	local command_file="$4"
	local requested_mode="$5"
	local reason="$6"
	mkdir -p "$(dirname "$artifact")"
	cat > "$artifact" <<STAGE
# $title

## Status

\`block\`

## Command

- Owner command: \`$owner\`
- Resolved command file: \`${command_file:-n/a}\`
- Requested mode: \`${requested_mode:-n/a}\`

## Blocked Reason

$reason
STAGE
}

record_refine_stage() {
	local stage_jsonl="$1"
	local stage="$2"
	local owner="$3"
	local command_file="$4"
	local artifact="$5"
	local status="$6"
	local verdict="$7"
	local blocked_reason="$8"
	local evidence_kind="${9:-}"
	local handoff_path="${10:-}"
	local receipt_path="${11:-}"
	local artifact_path="$artifact"
	if [[ -z "$evidence_kind" ]]; then
		if [[ "$status" == "block" ]]; then
			evidence_kind="blocked"
		elif [[ "$status" == "flag" ]]; then
			evidence_kind="handoff_prepared"
		elif [[ "$stage" == "Task Zero Observer Envelope" ]]; then
			evidence_kind="observer_envelope"
		elif [[ "$stage" == "Research decision" ]]; then
			evidence_kind="decision_record"
		elif [[ "$status" == "pass" && -n "$artifact" ]]; then
			evidence_kind="owner_artifact"
		else
			evidence_kind="unknown"
		fi
	fi
	if [[ -z "$handoff_path" && "$evidence_kind" == "handoff_prepared" ]]; then
		handoff_path="$artifact"
	fi
	if [[ -z "$receipt_path" && ( "$evidence_kind" == "receipt" || "$evidence_kind" == "observer_envelope" || "$evidence_kind" == "decision_record" ) ]]; then
		receipt_path="$artifact"
	fi
	jq -cn \
		--arg stage "$stage" \
		--arg owner "$owner" \
		--arg command_file "$command_file" \
		--arg artifact "$artifact" \
		--arg artifact_path "$artifact_path" \
		--arg handoff_path "$handoff_path" \
		--arg receipt_path "$receipt_path" \
		--arg evidence_kind "$evidence_kind" \
		--arg status "$status" \
		--arg verdict "$verdict" \
		--arg blocked_reason "$blocked_reason" \
		'{
			stage:$stage,
			owner:$owner,
			command_file:(if $command_file == "" then null else $command_file end),
			artifact:(if $artifact == "" then null else $artifact end),
			artifact_path:(if $artifact_path == "" then null else $artifact_path end),
			handoff_path:(if $handoff_path == "" then null else $handoff_path end),
			receipt_path:(if $receipt_path == "" then null else $receipt_path end),
			evidence_kind:$evidence_kind,
			status:$status,
			verdict:(if $verdict == "" then null else $verdict end),
			blocked_reason:(if $blocked_reason == "" then null else $blocked_reason end)
		}' >> "$stage_jsonl"
}

refine_artifact_is_usable() {
	local artifact="$1"
	[[ -s "$artifact" ]] || return 1
	if refine_artifact_is_runtime_handoff_stub "$artifact"; then
		return 1
	fi
	! grep -Eiq '(^|\n)[[:space:]]*(BLOCK:|(-[[:space:]]*)?Status:[[:space:]]*`?block`?([[:space:]]|$)|Blocked before task zero|[a-z-]+ did not produce command output)' "$artifact"
}

refine_artifact_is_runtime_handoff_stub() {
	local artifact="$1"
	[[ -s "$artifact" ]] || return 1
	grep -Eq '^# Arcanum Runtime-Native Handoff$' "$artifact" \
		&& grep -Eq '^STATUS:[[:space:]]*flag$' "$artifact"
}

refine_context_builder_persisted_is_usable() {
	local run_dir="$1"
	local context_pack="$run_dir/context-builder/context-pack.md"
	local context_index="$run_dir/context-builder/context-index.json"
	[[ -s "$context_pack" && -s "$context_index" ]] || return 1
	jq empty "$context_index" >/dev/null 2>&1
}

refine_stage_receipt_path() {
	local run_dir="$1"
	local stage_file="$2"
	printf '%s\n' "$run_dir/receipts/${stage_file%.md}.json"
}

refine_stage_receipt_is_valid() {
	local receipt="$1"
	local stage="$2"
	local owner="$3"
	[[ -s "$receipt" ]] || return 1
	jq -e \
		--arg stage "$stage" \
		--arg owner "$owner" \
		'
		def non_empty_string: type == "string" and length > 0;
		(.receipt_id | non_empty_string)
		and (.run_id | non_empty_string)
		and (.stage == $stage)
		and (.owner == $owner)
		and (.evidence_kind == "receipt")
		and ((.status // "") as $status | ["pass","flag","block","interrupted","timeout"] | index($status))
		and (.handoff_path | non_empty_string)
		and ((.artifact_paths // null) | type == "array")
		and ((.validation // null) | type == "array")
		and ((.blockers // null) | type == "array")
		and (if .status == "pass" then ((.artifact_paths // []) | length) > 0 else true end)
		and (if (.status == "block" or .status == "interrupted" or .status == "timeout") then (((.blockers // []) | length) > 0 or ((.validation // []) | length) > 0) else true end)
		' "$receipt" >/dev/null 2>&1
}

refine_stage_receipt_reason() {
	local receipt="$1"
	jq -r '
		(.blockers[0].reason // .validation[0].notes // ("Stage receipt reported " + (.status // "unknown") + "."))
	' "$receipt"
}

record_refine_stage_receipt() {
	local stage_jsonl="$1"
	local stage="$2"
	local owner="$3"
	local command_file="$4"
	local artifact="$5"
	local receipt="$6"
	local artifact_rel="$7"
	local receipt_rel="$8"
	local receipt_status reason stage_status verdict handoff_rel
	receipt_status="$(jq -r '.status' "$receipt")"
	reason="$(refine_stage_receipt_reason "$receipt")"
	handoff_rel="$(jq -r '.handoff_path // empty' "$receipt")"
	stage_status="$receipt_status"
	verdict="Stage receipt reported $receipt_status."
	case "$receipt_status" in
		pass)
			stage_status="pass"
			verdict="Stage receipt reported pass."
			;;
		flag)
			stage_status="flag"
			verdict="$reason"
			;;
		block)
			stage_status="block"
			;;
		interrupted|timeout)
			stage_status="flag"
			verdict="$reason"
			;;
	esac
	record_refine_stage "$stage_jsonl" "$stage" "$owner" "$command_file" "$artifact_rel" "$stage_status" "$verdict" "$(if [[ "$stage_status" == "block" ]]; then printf '%s' "$reason"; fi)" "receipt" "$handoff_rel" "$receipt_rel"
	printf '%s' "$stage_status"
}

kill_process_tree() {
	local pid="$1"
	local child
	for child in $(pgrep -P "$pid" 2>/dev/null || true); do
		kill_process_tree "$child"
	done
	kill "$pid" 2>/dev/null || true
}

run_refine_command_stage() {
	local stage_jsonl="$1"
	local run_dir="$2"
	local stage_file="$3"
	local stage_title="$4"
	local owner="$5"
	local requested_mode="$6"
	local stage_request="$7"
	local prior_status="$8"
	local dependency_reason="$9"
	local stage_adapter="${ARCANUM_REFINE_STAGE_ADAPTER:-local-skill}"
	local stage_timeout="${ARCANUM_REFINE_STAGE_TIMEOUT_SECONDS:-900}"
	local output_grace="${ARCANUM_REFINE_STAGE_OUTPUT_GRACE_SECONDS:-20}"
	local artifact="$run_dir/stages/$stage_file"
	local artifact_rel
	artifact_rel="$(rel_path "$artifact")"
	local receipt receipt_rel resume_command root_request resume_request
	receipt="$(refine_stage_receipt_path "$run_dir" "$stage_file")"
	receipt_rel="$(rel_path "$receipt")"
	root_request="${ARCANUM_REFINE_ROOT_REQUEST:-${request:-}}"
	if [[ -z "$root_request" ]]; then
		root_request="<original refine request>"
	fi
	if [[ "$root_request" == *"use existing run folder"* ]]; then
		resume_request="$root_request"
	else
		resume_request="$root_request use existing run folder $(rel_path "$run_dir")"
	fi
	resume_command="tools/arcanum --exec --adapter ${ARCANUM_RUNTIME_ADAPTER:-local-skill} --timeout 240 --output $(rel_path "$run_dir/RESULT.md") refine '$resume_request'"
	local command_rel
	command_rel="$(resolve_command "$owner" || true)"
	if [[ "$prior_status" != "pass" ]]; then
		write_refine_block_stage "$artifact" "$stage_title" "$owner" "$command_rel" "$requested_mode" "$dependency_reason"
		record_refine_stage "$stage_jsonl" "$stage_title" "$owner" "$command_rel" "$artifact_rel" "block" "" "$dependency_reason"
		printf 'block'
		return 0
	fi
	if [[ -z "$command_rel" ]]; then
		local reason="Command \`$owner\` could not be resolved through tools/arcanum."
		write_refine_block_stage "$artifact" "$stage_title" "$owner" "" "$requested_mode" "$reason"
		record_refine_stage "$stage_jsonl" "$stage_title" "$owner" "" "$artifact_rel" "block" "" "$reason"
		printf 'block'
		return 0
	fi
	local log_dir="$run_dir/stages/.logs"
	local log_file="$log_dir/${stage_file%.md}.log"
	mkdir -p "$log_dir"
	rm -f "$artifact"
	set +e
	(
		ARCANUM_REFINE_NATIVE=0 \
			ARCANUM_STAGE_RUN_ID="$(basename "$run_dir")" \
			ARCANUM_STAGE_TITLE="$stage_title" \
			ARCANUM_STAGE_OWNER="$owner" \
			ARCANUM_STAGE_REQUEST="$stage_request" \
			ARCANUM_STAGE_HANDOFF_PATH="$artifact_rel" \
			ARCANUM_STAGE_EXPECTED_RECEIPT_PATH="$receipt_rel" \
			ARCANUM_STAGE_RESUME_COMMAND="$resume_command" \
			"$repo_root/tools/arcanum" \
			--exec \
			--adapter "$stage_adapter" \
			--timeout "$stage_timeout" \
			--output "$artifact" \
			"$owner" \
			"$stage_request"
	) > "$log_file" 2>&1 &
	local stage_pid="$!"
	local stage_exit=""
	local stage_forced_complete="0"
	local usable_seen_at="0"
	local deadline=0
	if [[ "$stage_timeout" =~ ^[0-9]+$ && "$stage_timeout" -gt 0 ]]; then
		deadline=$((SECONDS + stage_timeout))
	fi
	while kill -0 "$stage_pid" 2>/dev/null; do
			if refine_artifact_is_usable "$artifact" || { [[ "$owner" == "context-builder" ]] && refine_context_builder_persisted_is_usable "$run_dir"; }; then
			if [[ "$usable_seen_at" -eq 0 ]]; then
				usable_seen_at="$SECONDS"
			fi
			if [[ "$output_grace" =~ ^[0-9]+$ && "$((SECONDS - usable_seen_at))" -ge "$output_grace" ]]; then
				kill_process_tree "$stage_pid"
				sleep 1
				kill -KILL "$stage_pid" 2>/dev/null || true
				wait "$stage_pid" 2>/dev/null || true
				stage_exit="0"
				stage_forced_complete="1"
				break
			fi
		else
			usable_seen_at="0"
		fi
		if [[ "$deadline" -gt 0 && "$SECONDS" -ge "$deadline" ]]; then
			kill_process_tree "$stage_pid"
			sleep 1
			kill -KILL "$stage_pid" 2>/dev/null || true
			wait "$stage_pid" 2>/dev/null || true
			stage_exit="124"
			break
		fi
		sleep 5
	done
	if [[ -z "$stage_exit" ]]; then
		wait "$stage_pid"
		stage_exit="$?"
	fi
	set -e
		if refine_artifact_is_runtime_handoff_stub "$artifact"; then
			if refine_stage_receipt_is_valid "$receipt" "$stage_title" "$owner"; then
				record_refine_stage_receipt "$stage_jsonl" "$stage_title" "$owner" "$command_rel" "$artifact" "$receipt" "$artifact_rel" "$receipt_rel"
				return 0
			fi
			local reason="Stage produced a runtime-native handoff stub only; owner-stage execution receipt is still required."
			record_refine_stage "$stage_jsonl" "$stage_title" "$owner" "$command_rel" "$artifact_rel" "flag" "$reason" "" "handoff_prepared" "$artifact_rel" ""
			printf 'flag'
			return 0
		fi
		if refine_artifact_is_usable "$artifact"; then
			local verdict="stage command produced output"
		if [[ "$stage_forced_complete" == "1" ]]; then
			verdict="stage command produced usable output; lingering child was stopped after output grace"
		fi
		if [[ "$stage_exit" -ne 0 ]]; then
			verdict="stage command produced usable output; wrapper exit was $stage_exit"
		fi
		record_refine_stage "$stage_jsonl" "$stage_title" "$owner" "$command_rel" "$artifact_rel" "pass" "$verdict" ""
			printf 'pass'
			return 0
		fi
		if [[ "$owner" == "context-builder" ]]; then
			local context_pack="$run_dir/context-builder/context-pack.md"
			local context_index="$run_dir/context-builder/context-index.json"
			local observer_envelope="$run_dir/context-builder/observer-envelope.json"
			if [[ -s "$context_pack" && -s "$context_index" ]] && jq empty "$context_index" >/dev/null 2>&1; then
				cat > "$artifact" <<CONTEXT_STAGE
# Context Builder Evidence Baseline

## Status

\`pass\`

## Verdict

Context Builder persisted command-owned handoff artifacts even though the Codex CLI did not write a final last-message artifact before wrapper closeout.

## Artifacts

- Context pack: \`$(rel_path "$context_pack")\`
- Context index: \`$(rel_path "$context_index")\`
- Observer envelope: \`$(rel_path "$observer_envelope")\`

## Validation

- \`jq empty $(rel_path "$context_index")\`: pass
CONTEXT_STAGE
				record_refine_stage "$stage_jsonl" "$stage_title" "$owner" "$command_rel" "$artifact_rel" "pass" "persisted context-builder handoff artifacts validated" "" "receipt" "" "$(rel_path "$context_index")"
				printf 'pass'
				return 0
			fi
		fi
		local reason="Stage command did not produce pass evidence. See $(rel_path "$log_file")."
	if [[ ! -s "$artifact" ]]; then
		write_refine_block_stage "$artifact" "$stage_title" "$owner" "$command_rel" "$requested_mode" "$reason"
	fi
	record_refine_stage "$stage_jsonl" "$stage_title" "$owner" "$command_rel" "$artifact_rel" "block" "" "$reason"
	printf 'block'
}

