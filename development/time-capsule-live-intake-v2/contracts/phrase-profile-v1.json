{
  "schema_version": "resonant.time-capsule.phrase-profile.schema.v1",
  "profile_id": "resonant.time-capsule.phrase-profile",
  "version": "1.0.0",
  "domain": "resonant-time-capsule/phrase/public-at-opening/v1",
  "status": "frozen",
  "input": {
    "type": "unicode_string",
    "empty_allowed": true
  },
  "output": {
    "normalization_form": "NFC",
    "length_unit": "unicode_grapheme_cluster"
  },
  "algorithm": [
    {
      "order": 1,
      "id": "require-unicode-scalar-string",
      "rule": "Input must be a JavaScript string containing no unpaired UTF-16 surrogate."
    },
    {
      "order": 2,
      "id": "reject-bidi-controls",
      "rule": "Reject Unicode bidi formatting, mark, and isolate controls before any normalization.",
      "code_points": [
        "U+061C",
        "U+200E",
        "U+200F",
        "U+202A-U+202E",
        "U+2066-U+2069"
      ]
    },
    {
      "order": 3,
      "id": "reject-invisible-separators",
      "rule": "Reject enumerated zero-width invisible separators; retain join controls required by scripts and emoji.",
      "code_points": [
        "U+180E",
        "U+200B",
        "U+2060",
        "U+FEFF"
      ],
      "explicitly_allowed_join_controls": [
        "U+200C",
        "U+200D"
      ]
    },
    {
      "order": 4,
      "id": "reject-disallowed-controls",
      "rule": "Reject C0 and C1 controls except TAB, LF, and CR, which continue to whitespace collapse.",
      "rejected_ranges": [
        "U+0000-U+0008",
        "U+000B-U+000C",
        "U+000E-U+001F",
        "U+007F-U+009F"
      ],
      "collapsible_controls": [
        "U+0009",
        "U+000A",
        "U+000D"
      ]
    },
    {
      "order": 5,
      "id": "trim-collapse-unicode-whitespace",
      "rule": "Replace each Unicode White_Space run with one U+0020, then remove a leading or trailing U+0020.",
      "replacement": "U+0020"
    },
    {
      "order": 6,
      "id": "normalize-nfc",
      "rule": "Normalize the collapsed string with Unicode NFC."
    },
    {
      "order": 7,
      "id": "segment-graphemes",
      "rule": "Segment the normalized string with Intl.Segmenter using locale und and granularity grapheme.",
      "runtime_api": "Intl.Segmenter",
      "locale": "und",
      "granularity": "grapheme",
      "missing_runtime_behavior": "fail_closed"
    },
    {
      "order": 8,
      "id": "enforce-grapheme-limit",
      "rule": "Accept between zero and 160 Unicode grapheme clusters inclusive.",
      "minimum": 0,
      "maximum": 160
    }
  ],
  "errors": {
    "input_type": "phrase_input_type",
    "invalid_unicode": "phrase_invalid_unicode",
    "directional_control": "phrase_directional_control",
    "invisible_separator": "phrase_invisible_separator",
    "control_character": "phrase_control_character",
    "segmenter_unavailable": "phrase_segmenter_unavailable",
    "too_long": "phrase_too_long"
  },
  "non_effects": [
    "does_not_create_an_envelope",
    "does_not_collect_or_publish_content",
    "does_not_make_content_visible_before_opening",
    "does_not_create_private_return_keys",
    "does_not_mint_or_allocate_tokens",
    "does_not_assign_reward_rank_membership_or_governance_power"
  ]
}
